@page "{id:int}"
@model Webapp.Pages.ProductDetailModel
<div class="container mt-5 d-flex justify-content-center">
    <div class="card p-4 shadow" style="max-width: 500px; width: 100%;">

        <a href="/Index" class="btn btn-secondary mb-3">⬅ Back to Home</a>

        @if (Model.Product != null)
        {
            <div class="text-center">
                <img src="@Model.Product.ImageUrl" class="img-fluid rounded shadow mb-3"
                     style="width:250px; height:250px; object-fit:cover;" />

                <h3>@Model.Product.ProductName</h3>
                <p class="text-muted">Category: @Model.Product.CategoryName</p>
                <p class="text-muted">Supplier: @Model.Product.SupplierName</p>

                <h5 class="text-danger mb-3">$@Model.Product.UnitPrice</h5>

                <p>@Model.Product.Description</p>

                <!-- ACTION BUTTONS -->
                <div class="d-flex justify-content-center gap-2 mt-4">
                    <form method="post" asp-page-handler="AddToCart">
                        <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                        <button type="submit" class="btn btn-success">
                            🛒 Add to Cart
                        </button>
                    </form>

                    <form method="post" asp-page-handler="AddToFavorite">
                        <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                        <button type="submit" class="btn btn-outline-danger">
                            ❤️ Add to Favorite
                        </button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-danger text-center">Product not found</div>
        }
    </div>
</div>
