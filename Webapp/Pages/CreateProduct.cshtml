@page
@model Webapp.Pages.CreateProductModel
@{
    ViewData["Title"] = "Add Product";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5" style="max-width: 800px;">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Add New Product</h3>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Product.ProductName" class="form-label">Product Name</label>
                    <input asp-for="Product.ProductName" class="form-control" placeholder="Enter product name" />
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Product.CategoryId" class="form-label">Category</label>
                        <select asp-for="Product.CategoryId" asp-items="Model.Categories" class="form-select">
                            <option selected disabled>Select category</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Product.SupplierId" class="form-label">Supplier</label>
                        <select asp-for="Product.SupplierId" asp-items="Model.Suppliers" class="form-select">
                            <option selected disabled>Select supplier</option>
                        </select>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Product.UnitPrice" class="form-label">Price</label>
                        <input asp-for="Product.UnitPrice" class="form-control" placeholder="0.00" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Product.UnitsInStock" class="form-label">Stock</label>
                        <input asp-for="Product.UnitsInStock" class="form-control" placeholder="0" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.Description" class="form-label">Description</label>
                    <textarea asp-for="Product.Description" class="form-control" rows="4" placeholder="Enter product description"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.ImageUrl" class="form-label">Image URL</label>
                    <input asp-for="Product.ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                </div>

                <div class="form-check mb-4">
                    <input asp-for="Product.IsActive" class="form-check-input" id="isActiveCheck" />
                    <label class="form-check-label" for="isActiveCheck">Active</label>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-page="/ManageProduct" class="btn btn-secondary">Back</a>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>
