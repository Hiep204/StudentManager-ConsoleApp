@page
@model Webapp.Pages.CheckoutModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5" style="max-width: 700px;">

    <div class="card shadow-sm border-0 p-4">
        <h3 class="mb-4 fw-bold">🧾 Checkout</h3>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">

            <!-- Receiver -->
            <div class="mb-3">
                <label class="form-label">Receiver Name</label>
                <input asp-for="CheckoutData.ReceiverName" class="form-control" placeholder="Nguyễn Văn A" />
            </div>

            <div class="mb-3">
                <label class="form-label">Phone</label>
                <input asp-for="CheckoutData.ReceiverPhone" class="form-control" placeholder="0123456789" />
            </div>

            <div class="mb-3">
                <label class="form-label">Address</label>
                <input asp-for="CheckoutData.ShippingAddress" class="form-control" placeholder="Hà Nội..." />
            </div>

            <!-- Payment Method -->
            <div class="mb-3">
                <label class="form-label">Payment Method</label>

                <div class="d-flex gap-3">
                    <div class="form-check">
                        <input class="form-check-input" type="radio"
                               asp-for="CheckoutData.PaymentMethod" value="COD" checked />
                        <label class="form-check-label">💵 COD</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="radio"
                               asp-for="CheckoutData.PaymentMethod" value="Banking" />
                        <label class="form-check-label">🏦 Banking</label>
                    </div>
                </div>
            </div>

            <!-- BANK SECTION -->
            <div id="bankSection" style="display:none;">

                <div class="mb-3">
                    <label class="form-label">Select Bank</label>
                    <select class="form-select" id="bankSelect">
                        <option>Vietcombank</option>
                        <option>Techcombank</option>
                        <option>BIDV</option>
                        <option>MB Bank</option>
                    </select>
                </div>

                <!-- Fake QR -->
                <div class="text-center mb-3">
                    <p class="fw-semibold">Scan QR to pay</p>
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=PAYMENT-DEMO"
                         class="border rounded p-2" />
                </div>

                <div class="alert alert-info text-center">
                    Nội dung chuyển khoản: <b>ORDER123</b>
                </div>

            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-primary w-100 mt-3">
                Place Order
            </button>

            <!-- Back -->
            <a href="/Cart" class="btn btn-outline-secondary w-100 mt-2">
                ← Back to Cart
            </a>

        </form>
    </div>
</div>

<script>
    const radios = document.querySelectorAll('input[name="CheckoutData.PaymentMethod"]');
    const bankSection = document.getElementById('bankSection');

    radios.forEach(r => {
        r.addEventListener('change', function () {
            if (this.value === "Banking") {
                bankSection.style.display = "block";
            } else {
                bankSection.style.display = "none";
            }
        });
    });
</script>