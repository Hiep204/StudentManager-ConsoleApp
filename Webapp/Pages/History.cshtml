@page
@model Webapp.Pages.HistoryModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <h3 class="fw-bold mb-4">📦 Order History</h3>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["Message"]
        </div>
    }

    @if (Model.Orders.Count == 0)
    {
        <div class="card shadow-sm text-center p-4">
            <h5>No orders yet 😢</h5>
            <a href="/Index" class="btn btn-primary mt-3">Start Shopping</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">

                <table class="table align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Payment</th>
                            <th>Total</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.Orders)
                        {
                            <tr>
                                <td class="fw-semibold">#@item.OrderId</td>

                                <td>
                                    @item.OrderDate.ToString("dd/MM/yyyy")
                                </td>

                                <!-- Status -->
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (item.Status == "Completed")
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>

                                <!-- Payment -->
                                <td>
                                    <div>
                                        <span class="fw-semibold">@item.PaymentMethod</span><br />
                                        @if (item.PaymentStatus == "Paid")
                                        {
                                            <span class="text-success small">✔ Paid</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger small">✖ Unpaid</span>
                                        }
                                    </div>
                                </td>

                                <!-- Total -->
                                <td class="fw-bold text-success">
                                    $@item.TotalAmount
                                </td>

                                <!-- Action -->
                                <td class="text-center">
                                    <a asp-page="/OrderDetail"
                                       asp-route-orderId="@item.OrderId"
                                       class="btn btn-sm btn-outline-primary rounded-pill">
                                        View Detail
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>

        <!-- Back -->
        <div class="mt-4">
            <a href="/Index" class="btn btn-outline-secondary">
                ← Continue Shopping
            </a>
        </div>
    }
</div>
