@page
@model Webapp.Pages.ManagerOrderModel

@{
    ViewData["Title"] = "Order Management";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">📦 Order Management</h2>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Payment</th>
                        <th>Total</th>
                        <th style="width:140px;">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Orders.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-muted py-4">
                                No orders found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Orders)
                        {
                            <tr>
                                <td class="fw-semibold">@item.OrderId</td>

                                <td class="fw-semibold text-start">
                                    @item.CustomerName
                                </td>

                                <td>
                                    @item.OrderDate.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    <span class="badge bg-info">
                                        @item.Status
                                    </span>
                                </td>

                                <td>
                                    <span class="badge bg-secondary">
                                        @item.PaymentMethod
                                    </span>
                                    <br />
                                    <small class="text-muted">
                                        @item.PaymentStatus
                                    </small>
                                </td>

                                <td class="fw-bold text-success">
                                    @item.TotalAmount.ToString("N0") ₫
                                </td>

                                <td>
                                    <a asp-page="/ManageOrderDetail"
                                       asp-route-id="@item.OrderId"
                                       class="btn btn-sm btn-outline-primary px-3">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>
