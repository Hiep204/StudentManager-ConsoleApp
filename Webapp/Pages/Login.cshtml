@page
@model Webapp.Pages.LoginModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            padding: 0;
            background: #f5f5f5;
            font-family: Arial, sans-serif;
        }

        .login-wrapper {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-card {
            width: 360px;
            background: white;
            border-radius: 30px;
            padding: 40px 30px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
        }

        .login-title {
            text-align: center;
            font-size: 32px;
            font-weight: bold;
            margin-bottom: 30px;
        }

        .form-control {
            height: 48px;
            border-radius: 12px;
            margin-bottom: 18px;
        }

        .login-btn {
            border-radius: 12px;
            height: 45px;
            font-weight: 600;
        }

        .bottom-link {
            text-align: center;
            margin-top: 14px;
        }

            .bottom-link a {
                text-decoration: none;
                font-size: 14px;
            }

        .divider {
            margin: 20px 0;
        }

        .error-text {
            text-align: center;
            margin-top: 15px;
            color: red;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-title">Login</div>

            <form method="post">
                <input asp-for="Email"
                       class="form-control"
                       placeholder="Email address" />

                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       placeholder="Password" />

                <button type="submit" class="btn btn-primary w-100 login-btn">
                    Log in
                </button>
            </form>

            <div class="bottom-link">
                <a asp-page="/Auth/ForgotPassword">Forgotten password?</a>
            </div>

            <hr class="divider" />

            <div class="bottom-link">
                <a asp-page="/Register" class="btn btn-success w-100 rounded-3">
                    Create new account
                </a>
            </div>

            <div class="bottom-link">
                <a href="/Index" class="text-muted">← Back to Home</a>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error-text">
                    @Model.ErrorMessage
                </div>
            }
        </div>
    </div>
</body>
</html>