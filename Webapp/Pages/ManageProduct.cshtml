@page
@model Webapp.Pages.ManageProductModel
    ViewData["Title"] = "Product Management";


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
<div class="container mt-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Product Management</h2>
        <a asp-page="/CreateProduct" class="btn btn-success btn-lg">
            <i class="bi bi-plus-lg"></i> Add Product
        </a>
    </div>

    <!-- Card wrapper -->
    <div class="card shadow-sm border-0">
        <div class="card-body">

            <!-- Table -->
            <div class="table-responsive">
                <table class="table table-hover align-middle text-center">
                    <thead class="table-light text-uppercase">
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Supplier</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Status</th>
                            <th style="width: 180px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Products.Count == 0)
                        {
                            <tr>
                                <td colspan="9" class="text-muted py-4">No products found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.Products)
                            {
                                <tr>
                                    <td>@item.ProductId</td>
                                    <td>
                                        <img src="@item.ImageUrl" alt="@item.ProductName"
                                             class="rounded" style="width:60px;height:60px;object-fit:cover;" />
                                    </td>
                                    <td class="fw-bold text-start">@item.ProductName</td>
                                    <td>@item.CategoryName</td>
                                    <td>@item.SupplierName</td>
                                    <td class="text-success fw-bold">$@item.UnitPrice</td>
                                    <td>@item.UnitsInStock</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-page="/EditProduct"
                                           asp-route-id="@item.ProductId"
                                           class="btn btn-sm btn-warning me-1 mb-1">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </a>

                                        <form method="post" asp-page-handler="Delete" class="d-inline">
                                            <input type="hidden" name="id" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-sm btn-danger mb-1"
                                                    onclick="return confirm('Delete this product?')">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-page="/Index" class="btn btn-secondary">Back</a>
                    </div>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- Optional: Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
