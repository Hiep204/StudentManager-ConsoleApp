@page
@model Webapp.Pages.ProfileModel
@{
    ViewData["Title"] = "Profile";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <h2 class="mb-4">My Profile</h2>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-success">@Model.Message</div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    Personal Information
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="UpdateProfile">
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input asp-for="UserProfile.FullName" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="UserProfile.Email" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Phone</label>
                            <input asp-for="UserProfile.Phone" class="form-control" />
                        </div>

                        <button type="submit" class="btn btn-primary">
                            Update Profile
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    Address Information
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="SaveAddress">
                        <input type="hidden" asp-for="Address.UserId" />

                        <div class="mb-3">
                            <label class="form-label">Receiver Name</label>
                            <input asp-for="Address.ReceiverName" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Receiver Phone</label>
                            <input asp-for="Address.ReceiverPhone" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Address Line</label>
                            <input asp-for="Address.AddressLine" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ward</label>
                            <input asp-for="Address.Ward" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">District</label>
                            <input asp-for="Address.District" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">City</label>
                            <input asp-for="Address.City" class="form-control" />
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="Address.IsDefault" class="form-check-input" />
                            <label class="form-check-label">Default address</label>
                        </div>

                        <button type="submit" class="btn btn-success">
                            Save Address
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>