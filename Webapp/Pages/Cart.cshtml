@page
@model Webapp.Pages.CartModel
@{
    ViewData["Title"] = "My Cart";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <h2 class="fw-bold mb-4">🛒 My Cart</h2>

    @if (Model.CartItems.Count == 0)
    {
        <div class="alert alert-light text-center shadow-sm p-4">
            <h5>Your cart is empty 😢</h5>
            <a href="/Index" class="btn btn-primary mt-3">Go Shopping</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th class="text-center">Price</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-center">Total</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.CartItems)
                        {
                            <tr>
                                <!-- Product -->
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@item.ImageUrl"
                                             style="width:70px;height:70px;object-fit:cover;border-radius:10px;" />
                                        <div>
                                            <div class="fw-semibold">@item.ProductName</div>
                                        </div>
                                    </div>
                                </td>

                                <!-- Price -->
                                <td class="text-center fw-semibold">
                                    $@item.UnitPrice
                                </td>

                                <!-- Quantity -->
                                <td class="text-center">
                                    <div class="d-inline-flex align-items-center border rounded-pill px-2 py-1">

                                        <form method="post" asp-page-handler="Decrease">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <button type="submit" class="btn btn-sm">−</button>
                                        </form>

                                        <span class="mx-2 fw-bold">@item.Quantity</span>

                                        <form method="post" asp-page-handler="Increase">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <button type="submit" class="btn btn-sm">+</button>
                                        </form>

                                    </div>
                                </td>
                                <!-- Total -->
                                <td class="text-center fw-bold text-success">
                                    $@item.Total
                                </td>

                                <!-- Action -->
                                <td class="text-center">
                                    <form method="post" asp-page-handler="Remove">
                                        <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            🗑
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>

        <!-- Tổng tiền -->
        <div class="d-flex justify-content-between mt-4">

            <!-- Continue Shopping -->
            <a href="/Index" class="btn btn-outline-secondary">
                ← Continue Shopping
            </a>

            <!-- Total -->
            <div class="card shadow-sm p-3" style="min-width: 250px;">
                <h5 class="mb-2">Total</h5>
                <h4 class="text-success fw-bold">$@Model.GrandTotal</h4>

                <a href="/Checkout" class="btn btn-primary w-100 mt-3">
                    Checkout
                </a>
            </div>

        </div>
    }
</div>
