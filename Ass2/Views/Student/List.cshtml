@model List<Ass2.Models.Student>

<h2>Student List</h2>

<form method="get" asp-action="List">
    <input type="text" name="keyword" placeholder="Enter your search" />
    <button type="submit">Submit</button>
</form>

<p>
    <a asp-action="Create">Add New Student</a>
</p>

<table border="1" cellpadding="10">
<tr>
        <th>Id</th>
        <th>Full Name</th>
        <th>Dob</th>
        <th>Action</th>
</tr>
    @foreach(var e in Model)
    {
        <tr>
            <td>@e.Id</td>
            <td>@e.FullName</td>
            <td>@e.Dob</td>
            <td>
                <a asp-action="Detail" asp-route-id="@e.Id">Detail</a> |
                <a asp-action="Edit" asp-route-id="@e.Id">Edit</a> |
                <form asp-action="Delete" asp-route-id="@e.Id" method="post" style="display:inline;"
                      onsubmit="return confirm('Bạn có chắc muốn xóa không?');">
                    <button type="submit">Delete</button>
                </form>
        </tr>
    }
</table>